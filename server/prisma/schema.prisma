// University Leadership Appointment System Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  SECRETARY
  DEPARTMENT_HEAD
  DEAN
  VICE_PRESIDENT
  PRESIDENT
  ADMIN
}

enum AppointmentStatus {
  PENDING        // Student submitted — awaiting Secretary review
  UNDER_REVIEW   // Secretary is reviewing
  FORWARDED      // Secretary forwarded to leader
  APPROVED       // Leader approved
  REJECTED       // Rejected by Secretary or Leader
  RESCHEDULED    // Rescheduled (pending re-approval)
  CANCELLED      // Cancelled by any party
  COMPLETED      // Appointment took place
}

enum RescheduleStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  APPOINTMENT_CREATED
  APPOINTMENT_APPROVED
  APPOINTMENT_REJECTED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_FORWARDED
  APPOINTMENT_REMINDER
  GENERAL
}

model User {
  id                  String    @id @default(uuid())
  fullName            String    @map("full_name")
  email               String    @unique
  password            String
  role                Role      @default(STUDENT)
  phone               String?
  department          String?
  office              String?
  fcmToken            String?   @map("fcm_token")
  isActive            Boolean   @default(true) @map("is_active")
  mustChangePassword  Boolean   @default(true) @map("must_change_password")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  requestedAppointments   Appointment[]  @relation("Requester")
  leaderAppointments      Appointment[]  @relation("Leader")
  secretaryAppointments   Appointment[]  @relation("Secretary")
  notifications           Notification[]
  auditLogs               AuditLog[]

  @@map("users")
}

model Appointment {
  id                  String             @id @default(uuid())
  requesterId         String             @map("requester_id")
  secretaryId         String?            @map("secretary_id")
  leaderId            String?            @map("leader_id")   // Assigned by Secretary during forwarding
  targetDepartment    String             @map("target_department")  // Student selects this
  title               String
  description         String?
  reason              String             // Reason for appointment (required)
  date                DateTime           @db.Date
  startTime           String             @map("start_time")
  endTime             String             @map("end_time")
  status              AppointmentStatus  @default(PENDING)
  location            String?
  rejectionReason     String?            @map("rejection_reason")
  cancellationReason  String?            @map("cancellation_reason")
  secretaryNote       String?            @map("secretary_note")
  leaderNote          String?            @map("leader_note")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  // Relations
  requester           User               @relation("Requester", fields: [requesterId], references: [id])
  leader              User?              @relation("Leader", fields: [leaderId], references: [id])
  secretary           User?              @relation("Secretary", fields: [secretaryId], references: [id])
  rescheduleRequests  RescheduleRequest[]
  auditLogs           AuditLog[]         @relation("AppointmentAudit")

  @@map("appointments")
}

model RescheduleRequest {
  id            String           @id @default(uuid())
  appointmentId String           @map("appointment_id")
  requestedById String           @map("requested_by_id")
  oldDate       DateTime         @map("old_date") @db.Date
  oldStartTime  String           @map("old_start_time")
  oldEndTime    String           @map("old_end_time")
  newDate       DateTime         @map("new_date") @db.Date
  newStartTime  String           @map("new_start_time")
  newEndTime    String           @map("new_end_time")
  reason        String
  status        RescheduleStatus @default(PENDING)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  appointment   Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("reschedule_requests")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  message   String
  title     String
  type      NotificationType @default(GENERAL)
  isRead    Boolean          @default(false) @map("is_read")
  data      Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  action        String
  entity        String
  entityId      String?     @map("entity_id")
  appointmentId String?     @map("appointment_id")
  details       Json?
  ipAddress     String?     @map("ip_address")
  timestamp     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id])
  appointment   Appointment? @relation("AppointmentAudit", fields: [appointmentId], references: [id])

  @@map("audit_logs")
}
