# Server
PORT=5000
NODE_ENV=development

# Database
# Use the Pooled connection string for the application (with -pooler)
DATABASE_URL="postgresql://neondb_owner:npg_lD96JYxRjEwH@ep-shy-dust-aprgg95w-pooler.c-7.us-east-1.aws.neon.tech/appointment-apps?sslmode=require&connect_timeout=30"
# Use the Direct connection string for Prisma migrations (without -pooler)
DIRECT_URL="postgresql://neondb_owner:npg_lD96JYxRjEwH@ep-shy-dust-aprgg95w.c-7.us-east-1.aws.neon.tech/appointment-apps?sslmode=require&connect_timeout=30"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="University Appointments <noreply@university.edu>"

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
